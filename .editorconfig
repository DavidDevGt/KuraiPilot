# Consistencia entre editores/IDEs de todo el equipo
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

[*.py]
indent_size = 4
max_line_length = 100

[*.{toml,yml,yaml,json}]
indent_size = 2

[*.{md,markdown}]
# Los trailing spaces son sintaxis en Markdown (line break)
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
